# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-2024-08-06
OPENAI_VISION_MODEL=gpt-4o

# Tavily
TAVILY_API_KEY=tvly-...

# Firebase Admin SDK
FIREBASE_PROJECT_ID=glucolens-demo
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@glucolens-demo.iam.gserviceaccount.com
FIREBASE_DATABASE_URL=https://glucolens-demo-default-rtdb.asia-southeast1.firebasedatabase.app
FIREBASE_STORAGE_BUCKET=glucolens-demo.appspot.com

# Feature flags
MYDIETCAM_ENABLED=false
TELEGRAM_ENABLED=false
EMAIL_ENABLED=false

# App
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
